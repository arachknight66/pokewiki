generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique @db.VarChar(255)
  username       String    @unique @db.VarChar(50)
  password_hash  String    @db.VarChar(255)
  
  profile_bio    String?   @db.Text
  avatar_url     String?   @db.Text
  
  preferences    Json      @default("{\"theme\": \"light\", \"notifications\": true}")
  
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  last_login     DateTime? @db.Timestamp(6)
  
  email_verified Boolean?  @default(false)
  is_active      Boolean?  @default(true)

  forum_threads  ForumThread[]
  forum_replies  ForumReply[]

  @@map("users")
}

model ForumThread {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  
  category      String    @db.VarChar(50)
  title         String    @db.VarChar(200)
  body          String    @db.Text
  
  views         Int?      @default(0)
  replies_count Int?      @default(0)
  
  pinned        Boolean?  @default(false)
  locked        Boolean?  @default(false)
  
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  replies       ForumReply[]

  @@map("forum_threads")
  @@index([category, created_at(sort: Desc)])
  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@index([views(sort: Desc)])
}

model ForumReply {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id     String    @db.Uuid
  user_id       String    @db.Uuid
  
  body          String    @db.Text
  
  upvotes       Int?      @default(0)
  downvotes     Int?      @default(0)
  net_votes     Int?      @default(0)
  
  is_edited     Boolean?  @default(false)
  edited_at     DateTime? @db.Timestamp(6)
  
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  thread        ForumThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("forum_replies")
  @@index([thread_id, created_at(sort: Asc)])
  @@index([user_id])
  @@index([net_votes(sort: Desc)])
  @@index([created_at(sort: Desc)])
}
